APP_NAME=XOStore
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=pl
APP_FALLBACK_LOCALE=en

SHOP_NAME=XOStore
SHOP_SEO_DEFAULT_TITLE="${SHOP_NAME}"
SHOP_SEO_DEFAULT_DESCRIPTION=
SHOP_SEO_OG_IMAGE=
SHOP_DEFAULT_LANGUAGE=pl
SHOP_FALLBACK_LANGUAGE=en
SHOP_CURRENCY=PLN
SHOP_CURRENCY_SYMBOL=zł
SHOP_CATALOG_PER_PAGE=24
SHOP_HOMEPAGE_BANNERS_ENABLED=true

ADMIN_EMAIL=admin@xostore.local
ADMIN_PASSWORD=password
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
MEDIA_DISK=bunny

# Bunny.net Storage + CDN (пароль зоны — Storage → FTP & API Access)
BUNNY_STORAGE_NAME=
BUNNY_STORAGE_PASSWORD=
BUNNY_STORAGE_REGION=de
BUNNY_CDN_URL=
# На локальном OpenServer при ошибке SSL: BUNNY_VERIFY_SSL=false
# BUNNY_VERIFY_SSL=

QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# adm.tools: host mail.adm.tools, port 465 + smtps (или 587 без scheme)
MAIL_MAILER=smtp
MAIL_SCHEME=smtps
MAIL_HOST=mail.adm.tools
MAIL_PORT=465
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="${SHOP_NAME}"

SHOP_CONTACT_EMAIL=hello@xostorebrand.com
SHOP_PHONE="+48 22 000 00 00"

# Newsletter (footer subscription + admin campaigns)
SHOP_NEWSLETTER_DEFAULT_GROUP=website
SHOP_NEWSLETTER_FROM_NAME="${SHOP_NAME}"
SHOP_NEWSLETTER_FROM_ADDRESS="${MAIL_FROM_ADDRESS}"

# Live chat (choose one): telegram | jivo | crisp | tawk
SHOP_CHAT_PROVIDER=
SHOP_CHAT_TELEGRAM_URL=
SHOP_CHAT_JIVO_WIDGET_ID=M0azBkj5wB
SHOP_CHAT_CRISP_WEBSITE_ID=
SHOP_CHAT_TAWK_PROPERTY_ID=
SHOP_CHAT_TAWK_WIDGET_ID=

# Product feeds (Google Merchant + Facebook Catalog)
SHOP_FEEDS_ENABLED=true
SHOP_FEEDS_DISK=public
SHOP_FEEDS_DIRECTORY=feeds
SHOP_FEEDS_REGENERATE_ON_SAVE=true
SHOP_FEEDS_GOOGLE_SLUG=google-merchant.xml
SHOP_FEEDS_FACEBOOK_SLUG=facebook-catalog.csv
SHOP_FEEDS_GOOGLE_CATEGORY="Apparel & Accessories > Clothing"
SHOP_FEEDS_PRODUCT_CONDITION=new

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
